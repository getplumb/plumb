    "@modelcontextprotocol/sdk": "^1.27.1",
    "@plumb/core": "workspace:*"
  },
  "devDependencies": {
    "openclaw": "^2026.3.2",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
