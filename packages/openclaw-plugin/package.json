{
  "name": "@plumb/openclaw-plugin",
  "version": "0.1.0",
  "description": "Plumb OpenClaw plugin — auto-ingest and memory injection for OpenClaw",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
