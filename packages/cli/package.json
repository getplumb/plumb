{
  "name": "plumb-memory",
  "version": "0.3.0",
  "description": "Plumb CLI — memory management and AI context tools",
  "license": "MIT",
  "author": "Clay Waters <hello@plumb.run>",
  "homepage": "https://plumb.run",
  "repository": {
    "type": "git",
    "url": "https://github.com/getplumb/plumb",
    "directory": "packages/cli"
  },
  "keywords": [
    "plumb",
    "memory",
    "ai",
    "cli",
    "export",
    "mcp"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "plumb": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx/esm --test 'src/**/*.test.ts'",
    "lint": "echo \"No lint yet\" && exit 0",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm build",
    "postinstall": "node -e \"console.log('\\n  🪣  Plumb installed!\\n  Run: plumb setup\\n')\""
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@getplumb/core": "workspace:*",
    "@inquirer/prompts": "^8.3.0",
    "commander": "^12.1.0",
    "openai": "^4.104.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.78.0"
  }
}
