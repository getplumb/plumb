{
  "name": "plumb-memory",
  "version": "0.1.0",
  "description": "Plumb CLI — plumb status / connect / export",
  "license": "MIT",
  "author": "Plumb Team",
  "homepage": "https://docs.getplumb.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/plumb-labs/plumb",
    "directory": "packages/cli"
  },
  "keywords": [
    "plumb",
    "memory",
    "ai",
    "cli",
    "export",
    "mcp"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "plumb": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx/esm --test 'src/**/*.test.ts'",
    "lint": "echo \"No lint yet\" && exit 0",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@getplumb/core": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
