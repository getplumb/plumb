{
  "name": "@getplumb/core",
  "version": "0.4.10",
  "description": "Plumb memory engine — storage abstraction, types, and local SQLite driver",
  "license": "MIT",
  "author": "Clay Waters <hello@plumb.run>",
  "homepage": "https://plumb.run",
  "repository": {
    "type": "git",
    "url": "https://github.com/getplumb/plumb",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "echo \"No lint yet\" && exit 0",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "@types/better-sqlite3": "^7.6.13",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "openai": "^4.80.0",
    "better-sqlite3": "^9.4.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@xenova/transformers": "^2.17.2"
  }
}
