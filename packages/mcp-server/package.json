{
  "name": "@getplumb/mcp-server",
  "version": "0.4.6",
  "description": "Plumb MCP stdio server — exposes memory tools to Claude and other MCP clients",
  "license": "MIT",
  "author": "Clay Waters <hello@plumb.run>",
  "homepage": "https://plumb.run",
  "repository": {
    "type": "git",
    "url": "https://github.com/getplumb/plumb",
    "directory": "packages/mcp-server"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "claude",
    "context",
    "knowledge-graph"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "plumb-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "echo \"No lint yet\" && exit 0",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@getplumb/core": "0.4.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
