{
  "name": "@plumb/mcp-server",
  "version": "0.1.0",
  "description": "Plumb MCP stdio server — exposes memory tools to Claude and other MCP clients",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "plumb-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
