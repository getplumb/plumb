  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@plumb/core": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
